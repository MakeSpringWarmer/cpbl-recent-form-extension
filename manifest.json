{
  "manifest_version": 3,
  "name": "CPBL Recent Form Visualizer",
  "description": "在 CPBL 官網球員頁與球隊逐日戰績頁上方顯示近期表現。",
  "version": "0.1.0",
  "permissions": [
    "storage"
  ],
  "host_permissions": [
    "https://cpbl.com.tw/*",
    "https://www.cpbl.com.tw/*"
  ],
  "content_scripts": [
    {
      "matches": [
        "https://cpbl.com.tw/team/person*",
        "https://www.cpbl.com.tw/team/person*",
        "https://cpbl.com.tw/team/follow*",
        "https://www.cpbl.com.tw/team/follow*",
        "https://cpbl.com.tw/team/dailyrecord*",
        "https://www.cpbl.com.tw/team/dailyrecord*"
      ],
      "js": [
        "src/core/recent-form.js",
        "src/adapters/cpbl-source.js",
        "src/ui/recent-form-panel.js",
        "src/settings/game-count.js",
        "src/content.js"
      ],
      "css": [
        "src/content.css"
      ],
      "run_at": "document_idle"
    }
  ]
}
